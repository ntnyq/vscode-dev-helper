{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "js/ts.experimental.useTsgo": true,
  "cSpell.words": [
    "bumpp",
    "changelogithub",
    "Cves",
    "esbuild",
    "GHSA",
    "Ghsas",
    "NPMRC",
    "oxfmt",
    "oxfmtrc",
    "oxlint",
    "oxlintrc",
    "taze",
    "tazerc",
    "tsdown",
    "tsgo",
    "unrs"
  ],
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "package.json",
        "cmd": "pnpm run generate:meta",
        "isAsync": true
      }
    ]
  }
}
